# Supabase の接続URL（SupabaseダッシュボードのSettings > Database > Connection stringからコピー）
DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.vfoatnaxwzqkmutxelvu.supabase.co:5432/postgres

# JWT認証用シークレット（任意の長い文字列）
JWT_SECRET=your-secret-key-change-this

# 管理者パスワード
ADMIN_PASSWORD=admin123

# Web Push通知用VAPIDキー（npx web-push generate-vapid-keys で生成）
VAPID_PUBLIC_KEY=your-vapid-public-key
VAPID_PRIVATE_KEY=your-vapid-private-key
VAPID_SUBJECT=mailto:admin@example.com

# 社長のブックマーク一発ログイン用キー（設定しなければ機能は無効）
# 例: openssl rand -hex 24 などで生成したランダム文字列
OWNER_QUICK_LOGIN_KEY=
